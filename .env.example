# URL base de la API Gateway
# Encuéntrala en: AWS Console → API Gateway → yt-mp3-api → Stage URL
# O ejecuta: cd ../yt-mp3-api/infra && terraform output api_gateway_url
EXPO_PUBLIC_API_URL=https://TU_API_GATEWAY_URL/dev

